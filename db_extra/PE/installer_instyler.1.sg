// Detect It Easy: detection rule file
// Author: hypn0 <hypn0@mail.ru>

meta("installer", "instyler");

function detect() {
    if (PE.compareEP("558bec81c4........53565733c08985") && //Borland Delphi (2)
        PE.compareOverlay("'IS'011a")) {
        sVersion = "1.6";
        sOptions = "zlib";
        bDetected = true;
    }

    return result();
}