// Detect It Easy: detection rule file
// Author: hypn0 <hypn0@mail.ru>

// by Linder Software
meta("installer", "SetupBuilder");

function detect() {
    if (PE.compareEP("a1........c1e0..a3........575133c0bf........b9........3bcf76") //Borland C++
    && (PE.isSignaturePresent(PE.getOverlayOffset(), 4096, "'SZDD'"))) {
        sOptions = "SZDD";
        bDetected = true;
    }

    return result();
}