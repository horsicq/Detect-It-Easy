// Detect It Easy: detection rule file
// Author: hypn0 <hypn0@mail.ru>

meta("installer", "Unknown");

//FI
function detect() {
    if (PE.compareEP("a1........c1e0..a3........575133c0bf........b9........3bcf76") //Borland C++
    && (PE.compareOverlay("00000000000000000000000000000000................................'FI'"))) {
        sName += " (FI)";
        sOptions = "GZIP";
        bDetected = true;
    }

    return result();
}