function detect(){if("2.0"===ZIP.getFileFormatVersion()&&"Deflate"===ZIP.getFileFormatOptions()){var e=Binary.getFileSuffix().toLowerCase(),e="mc"===e.substring(0,2)?e.match(/^mc(world|pack|addon)$/):null
if(e){switch(e[1]){case"world":sOptions="World"
break
case"pack":sOptions="Resource Pack"
break
case"addon":sOptions="Add-on"}sVersion="Bedrock Edition",bDetected=1}}return result()}init("format","Minecraft")