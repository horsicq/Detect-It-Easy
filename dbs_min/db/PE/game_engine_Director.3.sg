function detect(){return PE.isExportFunctionPresent("_FindEmbeddedMovie")||PE.isExportFunctionPresent("_GetCurrentEmbeddedMovie")||"Copyright © 1985-1996 Macromedia, Inc."==PE.getVersionStringInfo("LegalCopyright")||"Copyright © 1985-1997 Macromedia, Inc."==PE.getVersionStringInfo("LegalCopyright")?bDetected=1:"Director 8 Shockwave Studio"==PE.getVersionStringInfo("ProductName")||"Director 8.5 Shockwave Studio"==PE.getVersionStringInfo("ProductName")?(sOptions="Shockwave Studio",bDetected=1):"Copyright © 1985-2002 Macromedia, Inc."==PE.getVersionStringInfo("LegalCopyright")||"Copyright © 1985-2003 Macromedia, Inc."==PE.getVersionStringInfo("LegalCopyright")?bDetected=1:"Director MX 2004"==PE.getVersionStringInfo("ProductName")?(sOptions="MX 2004",bDetected=1):"Director 11.3"==PE.getVersionStringInfo("ProductName")||"Director 11.5"==PE.getVersionStringInfo("ProductName")?bDetected=1:"12.0.1 Development"==PE.getVersionStringInfo("ProductVersion")&&(sOptions="Development build",bDetected=1),bDetected&&(sVersion=File.cleanString(PE.getFileVersion())),result()}meta("game engine","Director")