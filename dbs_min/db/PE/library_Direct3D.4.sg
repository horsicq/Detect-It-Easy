function detect(){for(var e=0,r=/d3dx?(\d{1,2})/i,t=0;t<PE.getNumberOfImports();t++)(i=PE.getImportLibraryName(t).match(r))&&/^\d+$/.test(i[1])&&Number(i[1])>e&&(e=Number(i[1]))
for(var i,t=0;t<PE.getNumberOfExportFunctions();t++)(i=PE.getExportFunctionName(t).match(r))&&/^\d+$/.test(i[1])&&Number(i[1])>e&&(e=Number(i[1]))
return 0<e&&e<=13?(sVersion=String(e),bDetected=1):(sVersion=PE.isLibraryPresentExp(/^d3d(\d{1,2})/i)[1])&&0<sVersion&&sVersion<=13&&(bDetected=1),result()}meta("library","Direct3D")