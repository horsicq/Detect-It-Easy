function detect(){for(var e=0,r=/d3dx?(\d{1,2})/i,t=0;t<PE.getNumberOfImports();t++)(s=PE.getImportLibraryName(t).match(r))&&/^\d+$/.test(s[1])&&Number(s[1])>e&&(e=Number(s[1]))
for(var s,t=0;t<PE.getNumberOfExportFunctions();t++)(s=PE.getExportFunctionName(t).match(r))&&/^\d+$/.test(s[1])&&Number(s[1])>e&&(e=Number(s[1]))
return 0<e&&e<=13?(sVersion=String(e),bDetected=1):(sVersion=PE.isLibraryPresentExp(/^d3d(\d{1,2})/i))&&1<sVersion.length&&0<(sVersion=sVersion[1])&&sVersion<=13&&(bDetected=1),result()}meta("library","Direct3D")