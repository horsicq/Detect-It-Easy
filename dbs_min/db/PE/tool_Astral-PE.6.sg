function detect(){return PE.section[0].Name!==""||PE.isRichSignaturePresent()||0!==PE.getImageFileHeader("TimeDateStamp")||0!==PE.getImageOptionalHeader("CheckSum")||0!==PE.getMajorLinkerVersion()||0!==PE.getMinorLinkerVersion()||PE.isLibraryPresentExp(/^(?!.*\.dll$)\.[\\/]/i)&&(sOptions="IAT mutation",bDetected=!0),result()}meta("tool","Astral-PE")