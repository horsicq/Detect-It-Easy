// Detect It Easy: detection rule file
// Author: horsicq <horsicq@gmail.com>

meta("compiler", "Borland Kylix");

function detect() {
    if (ELF.isSectionNamePresent("borland.ressym") ||
        ELF.isSectionNamePresent("borland.reshash") ||
        ELF.isSectionNamePresent("borland.resdata") ||
        ELF.isSectionNamePresent("borland.resspare")) {
        bDetected = true;
    }

    sLang = "Pascal/C/C++";

    return result();
}
