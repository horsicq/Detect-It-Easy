// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://wiki.multimedia.cx/index.php/Engines/XPAT
meta("tool", "XCOMPILE");

function detect() {
    if (NE.compareOverlay("040002006608010000000200B60602")) {
        if (NE.compare("'XPAT Compile v1.0'", 0x000223b0)) {
            sVersion = "1.0";
            bDetected = true;
        }
    }

    return result();
}