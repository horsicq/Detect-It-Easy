// Detect It Easy: detection rule file
// Author: horsicq <horsicq@gmail.com>

meta("format", "pdf");

function detect() {
    var list_autor = PDF.getStringValuesByKey("/Author");

    for (var i = 0; i < list_autor.length; i++) {
        _setResult("personal data", "Author", "", list_autor[i]);
    }
}
