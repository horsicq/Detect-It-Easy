// Detect It Easy: detection rule file
// Author: horsicq <horsicq@gmail.com>

meta("virtual machine", "JVM");

function detect() {
    if (JAR.isVerbose()) {
        sName = JAR.getOperationSystemName();
        sVersion = JAR.getOperationSystemVersion();
        sOptions = JAR.getOperationSystemOptions();

        bDetected = true;
    }

    return result();
}
