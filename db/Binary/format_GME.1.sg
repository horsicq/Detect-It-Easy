// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://github.com/entropia/tip-toi-reveng/blob/master/GME-Format.md
meta("format", "GME");

function detect() {
    if (Binary.compare("'1CHOMPTECH DATA FORMAT CopyRight 2009'", 0x0020)) {
        sOptions = "2009";
        sVersion = Binary.getString(73, 17);
        bDetected = true;
    }

    return result();
}