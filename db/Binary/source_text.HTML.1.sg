// Detect It Easy: detection rule file
// Author: horsicq <horsicq@gmail.com>

meta("source", "HTML");

function detect() {
    var sText = Binary.getHeaderString();
    if (/^<\s*(!DOCTYPE\s+)?html\b[^>]*>/im.test(sText)) {
        bDetected = true;
    }

    sLang = "HTM";

    return result();
}
