// https://github.com/LiquidSevens/psx-models-bios-guide
meta("format", "PlayStation 1 BIOS");

function detect() {
    if (Binary.compare("1300083c3f240835801f013c")) {
        // TODO: validate the version string with regex
        sOptions = File.cleanString(Binary.getString(0x0000012c, 18));
        bDetected = true
    }

    return result();
}