function detect() {
    if (Binary.isHeuristicScan()) {
        main();
    }
}

function main() {
    switch (Binary.getFileSuffix().toLowerCase()) {
        case "bat":
        case "cmd":
            if (Binary.compare("FF FE")) {
                _setResult("~protection", "Generic", String(), "UTF-16 Obfuscation");
            }
    }
}