// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://github.com/temisu/ancient
meta("archive", "ANC-Cruncher");

function detect() {
    if (Binary.getSize() >= 8) {
        if (Binary.compare("'FVL0'0000")) {
            sOptions = "use ANC-Cruncher's CRLoad for unpack and run";
            bDetected = true;
        }
    }

    return result();
}