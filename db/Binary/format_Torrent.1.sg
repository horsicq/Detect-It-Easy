// https://en.wikipedia.org/wiki/Torrent_file
meta("format", "Torrent");

function detect() {
    if (Binary.compare("'d8:announce' %% %% ':'") && Binary.isSignaturePresent(0, 0x20, "'://' %% %% %%")) {
        bDetected = true;
    }

    return result();
}