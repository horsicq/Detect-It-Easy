// Detect It Easy: detection rule file
// Author: hypn0 <hypn0@mail.ru>

// https://www.compression.ru/arctest/self/pkzip-exp.htm
meta("sfx", "PKZIP-SFX");

function detect() {
    if (LX.compareEP("5aff......ff......ff......8b4424..a3........5068........5264678b16....8b")) { //BCC for OS/2 1994
        if (LX.compareOverlay("07'SFX.EXE'")) {
            bDetected = true;
        }
    }

    return result();
}