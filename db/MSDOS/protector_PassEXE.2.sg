meta("protector", "PassEXE");

function detect() {
    if (MSDOS.compareEP("061E0E0E071FBE....B9....871481......EB..C7......840087......FB1F584A")) {
        sVersion = "2.0";
        bDetected = true;
    }

    return result();
}
