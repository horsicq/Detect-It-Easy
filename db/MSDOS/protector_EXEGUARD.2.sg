meta("protector", "EXEGUARD");

function detect() {
    if (MSDOS.compareEP("BA....BF....EB$$E8$$$$53BB....EB$$EB$$5B0E075051535653BB....EB")) {
        sVersion = "1.3";
        bDetected = true;
    }

    return result();
}
