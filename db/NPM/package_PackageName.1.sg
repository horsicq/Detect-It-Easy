// Detect It Easy: detection rule file
// Author: horsicq <horsicq@gmail.com>

meta("package", "");

function detect() {
    var _sName = NPM.getPackageJsonRecord("name");

    if (_sName) {
        sName = _sName;
        sVersion = NPM.getPackageJsonRecord("version");
        bDetected = true;
    }

    return result();
}
