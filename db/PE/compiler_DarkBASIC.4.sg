// Detect It Easy: detection rule file
// Author: horsicq <horsicq@gmail.com>

meta("compiler", "DarkBASIC Professional");

function detect() {
    if (PE.isOverlayPresent() && PE.isSignaturePresent(PE.getOverlayOffset(), 2048, "'dbprocore.dll'")) {
        bDetected = true;
    }

    sLang = "DarkBASIC";

    return result();
}
