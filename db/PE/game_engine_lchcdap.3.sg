// https://www.mobygames.com/company/521/jumpstart-games-inc/
meta("game engine", "lchcdap");

function detect() {
    if (PE.getVersionStringInfo("FileDescription") == "lchcdap") {
        sVersion = File.cleanString(PE.getFileVersion());
        bDetected = true;
    }

    return result();
}