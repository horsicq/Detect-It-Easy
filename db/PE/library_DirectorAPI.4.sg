// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://wiki.scummvm.org/index.php?title=Director
meta("library", "Director API");

function detect() {
    if (PE.compareOverlay("..304a50")) {
        bDetected = true;
    } else if (PE.isLibraryPresent("DIRAPI.DLL")) {
        bDetected = true;
    }

    return result();
}