// https://www.clickteam.com/clickteam-fusion-2-5
meta("game engine", "Clickteam Fusion");

function detect() {
    if (PE.isExportFunctionPresent("zi32Support") && PE.compareOverlay("'wwwwI' 87 'G'")) {
        sVersion = "2.X+";
        bDetected = true;
    }

    return result();
}