// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://github.com/levanvn/PE_Packer
meta("packer", "PE Packer by levanvn");

function detect() {
    if (PE.is64()) return; // Doesn't support x64 binaries

    if (PE.isSectionNamePresent("packed") && PE.compareEP("558BEC81EC00010000C745F400004000C745..001000008B45F40345..8945")) {
        bDetected = true;
    }

    return result();
}