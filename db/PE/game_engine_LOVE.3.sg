// https://love2d.org/
meta("game engine", "LÖVE");

function detect() {
    if (PE.getVersionStringInfo("CompanyName") == "LÖVE World Domination Inc.") {
        sVersion = File.cleanString(PE.getFileVersion());
        bDetected = true;
    }

    return result();
}