// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

meta("debuginfo", "TASM32");

function detect() {
    var debugSection = PE.section[".debug"];

    if (debugSection &&
        PE.findString(debugSection.FileOffset, debugSection.FileSize, "FB0A") != -1) {
        bDetected = true;
    }

    return result();
}