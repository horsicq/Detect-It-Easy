// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>
// Rewritten by: DosX

// https://www.softpedia.com/get/Programming/File-Editors/LordPE.shtml
meta("tool", "LordPE");

function detect() {
    if (PE.getDosStubSize() === 0 && PE.isSignaturePresent(0x00, 0x80, "'[LordPE]'")) {
        sOptions = "rebuilded";
        bDetected = true;
    }

    return result();
}