// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de> 

// https://malpedia.caad.fkie.fraunhofer.de/details/win.atmspitter
meta("library", "CSCWCNG");

function detect() {
    if (PE.isLibraryPresent("CSCWCNG.dll")) {
        sOptions = "ATMSplitter, Be careful!";
        bDetected = true;
    }

    return result();
}