// Detect It Easy: detection rule file
// Author: horsicq <horsicq@gmail.com>

meta("sfx", "WinACE");

function detect() {
    if (/WinACE|UNACE/i.test(PE.getVersionStringInfo("InternalName"))) {
        sVersion = PE.getVersionStringInfo("FileVersion");
        bDetected = true;
    }

    return result();
}
