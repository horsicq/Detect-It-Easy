// Detect It Easy: detection rule file
// Author: th3spis 10-03-2026
// Simply detect UPX sections for when other UPX rules were not matching.

meta("packer", "UPX");

function detect() {
    if (PE.isNet()) return; // Doesn't support .NET

    if (PE.isSectionNamePresent("UPX0") && PE.isSectionNamePresent("UPX1") && PE.isSectionNamePresent("UPX2")) {
        bDetected = true;
    }

    return result();
}

