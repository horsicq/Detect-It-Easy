// https://smallbasic-publicwebsite.azurewebsites.net/
meta("compiler", "Microsoft Small Basic");

function detect() {
    if (PE.isNetObjectPresent("SmallBasicLibrary") && PE.isNetObjectPresent("SmallBasicApplication")) {
        bDetected = true;
    }

    sLang = "Small Basic";

    return result();
}