// https://en.wikipedia.org/wiki/RenderWare
meta("game engine", "RenderWare");

function detect() {
    if (PE.isSectionNamePresent("_rwdseg") && PE.isSectionNamePresent("_rwcseg")) {
        bDetected = true;
    }

    return result();
}