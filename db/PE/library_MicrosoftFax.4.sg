// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://learn.microsoft.com/en-us/windows/win32/api/_fax/
meta("library", "Microsoft Fax");

function detect() {
    if (PE.isLibraryPresentExp(/^FXS(?:API|TIFF|CLNTR)/i)) {
        bDetected = true;
    }

    return result();
}