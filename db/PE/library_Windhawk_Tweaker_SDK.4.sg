// https://windhawk.net/
meta("library", "Windhawk Tweaker SDK");

function detect() {
    if (PE.isLibraryPresent("windhawk.dll") || PE.isLibraryPresent("libc++.whl") || PE.isLibraryPresent("libunwind.whl")) {
        bDetected = true;
    }

    return result();
}