// https://github.com/google/brotli
meta("library", "Brotli");

function detect() {
    if (PE.isLibraryPresentExp(/brotli(?:dec|enc)/i)) {
        bDetected = true;
    } else if (PE.isExportFunctionPresentExp(/^Brotli(?:Decoder|Encoder)/)) {
        sOptions = "static"; // EAT
        bDetected = true;
    }

    return result();
}