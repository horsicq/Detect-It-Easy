// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://github.com/z3r0d4y5/Simple-PE32-Packer
meta("packer", "Uchiha");

function detect() {
    if (PE.is64()) return; // Doesn't support x64 binaries

    if (PE.isSectionNamePresent(".Uchiha") && PE.compareEP("90909068007040009090906800104000")) {
        bDetected = true;
    }

    return result();
}