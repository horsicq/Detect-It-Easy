meta("packer", "PyPePacker");

function detect() {
    if (PE.isLibraryPresent("python3.dll") && PE.compareOverlay("504B0304140000000000........................................5F5F6D61696E5F5F2E70790D0A66726F6D20507950654C6F6164657220696D706F72742028")) {
        bDetected = true;
    }

    return result();
}