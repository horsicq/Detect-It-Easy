// https://www.amd.com/en/products/graphics/technologies/fidelityfx.html
meta("library", "AMD FidelityFX");

function detect() {
    if (PE.isLibraryPresent("amd_fidelityfx_dx12.dll")) {
        bDetected = true;
    }

    return result();
}