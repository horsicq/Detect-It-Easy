// Detect It Easy: detection rule file
// Author: horsicq <horsicq@gmail.com>

meta("library", "Costura.Fody");

function detect() {
    if (PE.isNetGlobalCctorPresent() && (PE.isNetObjectPresent("costura.costura.dll.compressed") || PE.isNetUStringPresent("costura.costura.dll.compressed"))) {
        bDetected = true;
    }

    return result();
}
