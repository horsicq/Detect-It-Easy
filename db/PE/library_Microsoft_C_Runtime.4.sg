meta("library", "Microsoft C/C++ Runtime");

function detect() {
    if (PE.isLibraryPresentExp(/^vcruntime140(d|_1(d)?|(_1(d)?)?_[a-z0-9]+)?(\.dll)?$/i)) {
        sOptions = "dynamic";
        bDetected = true;
    }

    return result();
}