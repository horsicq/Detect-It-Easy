// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://github.com/senko37/pe-packer
meta("packer", "pinkie-pie");

function detect() {
    if (PE.is64()) return; // Doesn't support x64 binaries

    var kucdSection = PE.section[".kucd"];

    if (kucdSection) {
        sVersion = "0.4";
        bDetected = (PE.findSignature(kucdSection.FileOffset, kucdSection.FileSize, "64A1300000008B7008BB0001000031C9") !== -1);
    }

    return result();
}