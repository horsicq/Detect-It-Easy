// https://web.archive.org/web/20240616203445/http://www.chosenbytes.com/
meta("protector", "Code-Lock");

function detect() {
    if (PE.isLibraryPresent("CODE-LOCK.OCX")) {
        bDetected = true;
    }

    return result();
}
