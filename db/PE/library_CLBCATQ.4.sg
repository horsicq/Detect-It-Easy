// https://windows10dll.nirsoft.net/clbcatq_dll.html
meta("library", "COM+ Configuration Catalog (CLBCATQ)");

function detect() {
    if (PE.isLibraryPresent("CLBCATQ.DLL")) {
        bDetected = true;
    }

    return result();
}