// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://learn.microsoft.com/en-us/windows/win32/api/vfw/nf-vfw-avifileinfo
meta("library", "AVIFIL");

function detect() {
    if (PE.isLibraryPresent("AVIFIL32.dll")) {
        bDetected = true;
    }

    return result();
}