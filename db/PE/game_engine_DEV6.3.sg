// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://wiki.scummvm.org/index.php?title=Gob/DEV6_Information
meta("game engine", "DEV6");

function detect() {
    var dataSection = PE.section[".data"];

    if (dataSection) {
        if (PE.findString(dataSection.FileOffset, dataSection.FileSize, "X:\\UTILS\\DEV6.EXE") !== -1) {
            bDetected = true;
        }
    }
    else if ((dataSection = PE.section["DATA"])) {
        if (PE.findString(dataSection.FileOffset, dataSection.FileSize, "X:\\UTILS\\DEV6.EXE") !== -1) {
            bDetected = true;
        }
    }

    return result();
}