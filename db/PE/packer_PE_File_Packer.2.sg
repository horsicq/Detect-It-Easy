// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://github.com/Chronoss3/PE-File-Packer
meta("packer", "PE File Packer");

function detect() {
    var araaraSection = PE.section[".araara"];

    if (araaraSection) {
        bDetected = (PE.findSignature(araaraSection.FileOffset, araaraSection.FileSize, "..C0EDFE00DAEDFE00DAEDFECCCCCCCC") !== -1);
    }

    return result();
}