// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://github.com/drinr1/permafrost
meta("cryptor", "permafrost");

function detect() {
    if (PE.is64()) {
        if (PE.compareEP("E8000000005D488D9D........48BE................49BA25232284E49CF2CB49BBB301000000010000488DBDFBFFFFFFB90F000000")) {
            sVersion = "x64 only";
            bDetected = true;
        }
    }

    return result();
}