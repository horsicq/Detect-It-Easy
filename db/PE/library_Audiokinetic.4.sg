// https://www.audiokinetic.com/en/
meta("library", "Audiokinetic");

function detect() {
    if (PE.isFunctionPresent("AkTlsAllocateSlot")) {
        bDetected = true;
    } else if (PE.isExportFunctionPresent("AkTlsAllocateSlot")) {
        sOptions = "static"; // EAT
        bDetected = true;
    }

    return result();
}