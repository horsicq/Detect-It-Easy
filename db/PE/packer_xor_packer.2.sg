// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://github.com/eternaleclipse/xor_packer
meta("packer", "xor_packer");

function detect() {
    var newSection = PE.section[".new"];

    if (newSection && PE.isSignaturePresent(newSection.FileOffset, newSection.FileSize, "488D05F9....FF48B9")) {
        sOptions = "x64";
        bDetected = true;
    }

    return result();
}