// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://godotengine.org
meta("game engine", "Godot");

function detect() {
    if (PE.getVersionStringInfo("FileDescription") == "Godot Engine") {
        sVersion = PE.getFileVersion();
        bDetected = true;
    }

    return result();
}