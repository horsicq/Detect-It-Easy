// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://wiki.scummvm.org/index.php?title=Gob/DEV7_Information#cknet.dll
meta("library", "CkNet");

function detect() {
    var dataSection = PE.section[".data"];

    if (dataSection) {
        if (PE.findString(dataSection.FileOffset, dataSection.FileSize, "CkNet.dll") !== -1) {
            bDetected = true;
        }
    }

    return result();
}