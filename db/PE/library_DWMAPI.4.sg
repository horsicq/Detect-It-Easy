// Detect It Easy: detection rule file
// Author: BJNFNE <bjnfne@web.de>

// https://windows10dll.nirsoft.net/dwmapi_dll.html
meta("library", "Microsoft Desktop Window Manager API");

function detect() {
    if (PE.isLibraryPresent("dwmapi.dll")) {
        bDetected = true;
    }

    return result();
}