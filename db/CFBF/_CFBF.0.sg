meta("format", "Compound File Binary Format");

function detect() {
    sName = CFBF.getFileFormatName();
    sVersion = CFBF.getFileFormatVersion();
    sOptions = CFBF.getFileFormatOptions();

    bDetected = true;

    return result();
}
