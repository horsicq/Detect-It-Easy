// Detect It Easy: detection rule file
// Author: horsicq <horsicq@gmail.com>

meta("format", "Archive");

function detect() {
    if (Archive.isVerbose()) {
        sName = Archive.getFileFormatName();
        sVersion = Archive.getFileFormatVersion();
        sOptions = Archive.getFileFormatOptions();
        
        if (sName) {
            bDetected = true;
        }
    }

    return result();
}
