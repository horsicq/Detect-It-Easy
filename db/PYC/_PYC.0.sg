// Detect It Easy: detection rule file
// Author: horsicq <horsicq@gmail.com>

meta("format", "PYC");

function detect() {
    sName = PYC.getFileFormatName();
    sVersion = PYC.getFileFormatVersion();
    sOptions = PYC.getFileFormatOptions();

    bDetected = true;

    return result();
}
