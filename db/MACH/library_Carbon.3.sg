// Detect It Easy: detection rule file
// Author: horsicq <horsicq@gmail.com>

meta("library", "Carbon");

function detect() {
    if (MACH.isLibraryPresent("Carbon")) {
        bDetected = true;
    } else if (MACH.isLibraryPresent("CarbonCore")) {
        bDetected = true;
    }

    return result();
}
